
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Descriptive user profile with cinema identity and preferences.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "username": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "dateJoined": { "type": "string", "format": "date-time" },
        "personality": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "description": { "type": "string" }
          }
        },
        "favoriteGenreIds": { "type": "array", "items": { "type": "string" } },
        "friends": { "type": "object" }
      },
      "required": ["id", "email", "username"]
    },
    "WatchlistEntry": {
      "title": "WatchlistEntry",
      "type": "object",
      "description": "A detailed movie record containing original metadata (titles, posters, genres) for clear database visualization.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "movieId": { "type": "string" },
        "movieData": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "genres": { "type": "array", "items": { "type": "string" } },
            "tmdbRating": { "type": "number" },
            "releaseDate": { "type": "string" },
            "overview": { "type": "string" },
            "posterUrl": { "type": "string" },
            "backdropUrl": { "type": "string" }
          }
        },
        "addedDate": { "type": "string", "format": "date-time" },
        "isWatched": { "type": "boolean" },
        "watchDate": { "type": "string", "format": "date-time" },
        "personalRating": { "type": "number" },
        "notes": { "type": "string" },
        "rewatchCount": { "type": "number" },
        "isFavorite": { "type": "boolean" },
        "remindMe": { "type": "boolean" }
      },
      "required": ["userId", "movieId", "isWatched", "movieData"]
    },
    "SceneMemory": {
      "title": "SceneMemory",
      "type": "object",
      "description": "A specific cinematic moment with movie titles and posters for context.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "movieId": { "type": "string" },
        "movieTitle": { "type": "string" },
        "posterUrl": { "type": "string" },
        "timestamp": { "type": "string" },
        "quote": { "type": "string" },
        "note": { "type": "string" },
        "addedDate": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "movieId", "timestamp", "movieTitle"]
    },
    "Comment": {
      "title": "Comment",
      "type": "object",
      "description": "A user's comment on a movie, including their descriptive username.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "watchlistEntryId": { "type": "string" },
        "text": { "type": "string" },
        "commentDate": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "username", "text", "commentDate"]
    },
    "WatchParty": {
      "title": "WatchParty",
      "type": "object",
      "description": "A collaborative room for group movie experiences.",
      "properties": {
        "id": { "type": "string" },
        "hostId": { "type": "string" },
        "hostName": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "scheduledAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["voting", "ready", "finished"] },
        "selectedMovieId": { "type": "string" },
        "selectedMovieTitle": { "type": "string" },
        "selectedMoviePoster": { "type": "string" }
      },
      "required": ["id", "hostId", "title", "status", "scheduledAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Root path for descriptive user data."
    },
    "/users/{userId}/watchlist/{movieId}": {
      "schema": { "$ref": "#/backend/entities/WatchlistEntry" },
      "description": "User's personal movie collection with original metadata."
    },
    "/users/{userId}/sceneMemories/{memoryId}": {
      "schema": { "$ref": "#/backend/entities/SceneMemory" },
      "description": "Captured cinematic moments with movie titles and posters."
    },
    "/users/{userId}/notifications/{notifId}": {
      "schema": { "type": "object" },
      "description": "Personal alerts and party invites."
    },
    "/comments/{commentId}": {
       "schema": { "$ref": "#/backend/entities/Comment" },
      "description": "Public movie discussions."
    },
    "/watchParties/{partyId}": {
      "schema": { "$ref": "#/backend/entities/WatchParty" },
      "description": "Collaborative watch party rooms."
    }
  }
}
