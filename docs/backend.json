
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Descriptive user profile with cinema identity and gamification stats.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "username": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "dateJoined": { "type": "string", "format": "date-time" },
        "personality": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "description": { "type": "string" }
          }
        },
        "favoriteGenreIds": { "type": "array", "items": { "type": "string" } },
        "gamification": {
          "type": "object",
          "properties": {
            "streak": { "type": "number" },
            "lastWatchDate": { "type": "string", "format": "date-time" },
            "badges": { "type": "array", "items": { "type": "string" } },
            "totalWatched": { "type": "number" }
          }
        }
      },
      "required": ["id", "email", "username"]
    },
    "WatchlistEntry": {
      "title": "WatchlistEntry",
      "type": "object",
      "description": "A detailed movie record containing original metadata (titles, posters, genres) for clear database visualization.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "movieId": { "type": "string" },
        "movieData": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "genres": { "type": "array", "items": { "type": "string" } },
            "tmdbRating": { "type": "number" },
            "releaseDate": { "type": "string" },
            "overview": { "type": "string" },
            "posterUrl": { "type": "string" },
            "backdropUrl": { "type": "string" },
            "runtime": { "type": "number" },
            "director": { "type": "string" },
            "cast": { "type": "array", "items": { "type": "string" } }
          }
        },
        "addedDate": { "type": "string", "format": "date-time" },
        "isWatched": { "type": "boolean" },
        "watchDate": { "type": "string", "format": "date-time" },
        "personalRating": { "type": "number" },
        "notes": { "type": "string" },
        "rewatchCount": { "type": "number" },
        "isFavorite": { "type": "boolean" },
        "remindMe": { "type": "boolean" }
      },
      "required": ["userId", "movieId", "isWatched", "movieData"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Root path for descriptive user data."
    },
    "/users/{userId}/watchlist/{movieId}": {
      "schema": { "$ref": "#/backend/entities/WatchlistEntry" },
      "description": "User's personal movie collection with original metadata."
    }
  }
}
