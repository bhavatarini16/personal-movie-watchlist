{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Full user profile with preferences and social data.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "username": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "dateJoined": { "type": "string", "format": "date-time" },
        "personality": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "description": { "type": "string" }
          }
        },
        "favoriteGenreIds": { "type": "array", "items": { "type": "string" } },
        "friends": {
          "type": "object",
          "description": "Map of userId to boolean for relationship tracking."
        }
      },
      "required": ["id", "email", "username"]
    },
    "WatchlistEntry": {
      "title": "WatchlistEntry",
      "type": "object",
      "description": "A rich movie entry in a user's collection, containing full movie metadata.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "movieId": { "type": "string" },
        "movieData": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "genres": { "type": "array", "items": { "type": "string" } },
            "tmdbRating": { "type": "number" },
            "releaseDate": { "type": "string" },
            "overview": { "type": "string" },
            "posterUrl": { "type": "string" },
            "backdropUrl": { "type": "string" },
            "runtime": { "type": "number" },
            "cast": { "type": "array", "items": { "type": "string" } },
            "director": { "type": "string" }
          }
        },
        "addedDate": { "type": "string", "format": "date-time" },
        "isWatched": { "type": "boolean" },
        "watchDate": { "type": "string", "format": "date-time" },
        "personalRating": { "type": "number" },
        "notes": { "type": "string" },
        "rewatchCount": { "type": "number" },
        "isFavorite": { "type": "boolean" },
        "remindMe": { "type": "boolean" }
      },
      "required": ["userId", "movieId", "isWatched", "movieData"]
    },
    "SceneMemory": {
      "title": "SceneMemory",
      "type": "object",
      "description": "A specific cinematic moment captured by a user with descriptive metadata.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "movieId": { "type": "string" },
        "movieTitle": { "type": "string" },
        "posterUrl": { "type": "string" },
        "timestamp": { "type": "string" },
        "quote": { "type": "string" },
        "note": { "type": "string" },
        "addedDate": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "movieId", "timestamp", "movieTitle"]
    },
    "WatchParty": {
      "title": "WatchParty",
      "type": "object",
      "description": "A collaborative movie watching room with host and selected movie details.",
      "properties": {
        "id": { "type": "string" },
        "hostId": { "type": "string" },
        "hostName": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "scheduledAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["voting", "ready", "finished"] },
        "selectedMovieId": { "type": "string" },
        "selectedMovieTitle": { "type": "string" },
        "selectedMoviePoster": { "type": "string" }
      },
      "required": ["id", "hostId", "title", "status", "scheduledAt"]
    },
    "Notification": {
      "title": "Notification",
      "type": "object",
      "description": "A user alert containing sender and party context.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "partyId": { "type": "string" },
        "partyTitle": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Comment": {
      "title": "Comment",
      "type": "object",
      "description": "A social comment with user and movie context.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "watchlistEntryId": { "type": "string" },
        "text": { "type": "string" },
        "commentDate": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "User profiles and settings."
    },
    "/users/{userId}/watchlist/{movieId}": {
      "schema": { "$ref": "#/backend/entities/WatchlistEntry" },
      "description": "Personal movie tracking queue with full metadata."
    },
    "/users/{userId}/sceneMemories/{memoryId}": {
      "schema": { "$ref": "#/backend/entities/SceneMemory" },
      "description": "Cinematic highlights with movie context."
    },
    "/users/{userId}/notifications/{notifId}": {
      "schema": { "$ref": "#/backend/entities/Notification" },
      "description": "Activity alerts and invites."
    },
    "/watchParties/{partyId}": {
      "schema": { "$ref": "#/backend/entities/WatchParty" },
      "description": "Watch party room metadata."
    },
    "/watchParties/{partyId}/members/{userId}": {
      "schema": { "type": "object" },
      "description": "Party participants with user details."
    },
    "/watchParties/{partyId}/nominations/{nomId}": {
      "schema": { "type": "object" },
      "description": "Movie suggestions for the party including poster and title."
    },
    "/comments/{commentId}": {
      "schema": { "$ref": "#/backend/entities/Comment" },
      "description": "Global movie discussions with original user data."
    }
  }
}