
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile, containing personal information and references to their preferences and movie personality.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity."
        },
        "username": {
          "type": "string",
          "description": "A unique display name chosen by the user."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "avatarUrl": {
          "type": "string",
          "description": "URL to the user's profile avatar image.",
          "format": "uri"
        },
        "dateJoined": {
          "type": "string",
          "description": "The date and time when the user registered.",
          "format": "date-time"
        },
        "moviePersonalityTypeId": {
          "type": "string",
          "description": "Reference to the MoviePersonalityType assigned to the user after taking the quiz."
        },
        "favoriteGenreIds": {
          "type": "array",
          "description": "References to Genres that the user considers favorites.",
          "items": {
            "type": "string"
          }
        },
        "friends": {
          "type": "object",
          "description": "Denormalized map of friend UIDs for security rules."
        }
      },
      "required": [
        "id",
        "username",
        "email",
        "dateJoined"
      ]
    },
    "Movie": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Movie",
      "type": "object",
      "description": "Represents a movie, storing its details primarily sourced from TMDB.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Movie entity."
        },
        "tmdbId": {
          "type": "string",
          "description": "The unique identifier from TMDB."
        },
        "title": {
          "type": "string",
          "description": "The official title of the movie."
        },
        "overview": {
          "type": "string",
          "description": "A brief summary of the movie."
        },
        "releaseDate": {
          "type": "string",
          "description": "The official release date.",
          "format": "date"
        },
        "posterUrl": {
          "type": "string",
          "description": "URL to the movie's poster image."
        },
        "backdropUrl": {
          "type": "string",
          "description": "URL to the movie's backdrop image."
        }
      },
      "required": [
        "id",
        "tmdbId",
        "title",
        "overview",
        "releaseDate",
        "posterUrl"
      ]
    },
    "WatchlistEntry": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "WatchlistEntry",
      "type": "object",
      "description": "Represents a movie in a user's watchlist.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the entry."
        },
        "userId": {
          "type": "string",
          "description": "Owner UID."
        },
        "movieId": {
          "type": "string",
          "description": "TMDB Movie ID."
        },
        "addedDate": {
          "type": "string",
          "format": "date-time"
        },
        "isWatched": {
          "type": "boolean"
        },
        "isFavorite": {
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "userId",
        "movieId",
        "addedDate",
        "isWatched"
      ]
    },
    "SceneMemory": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SceneMemory",
      "type": "object",
      "description": "Represents a saved movie scene memory, including timestamp, quote, and notes.",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "movieId": {
          "type": "string"
        },
        "movieTitle": {
          "type": "string"
        },
        "posterUrl": {
          "type": "string"
        },
        "timestamp": {
          "type": "string",
          "description": "The timestamp of the scene (e.g., 01:42:15)."
        },
        "quote": {
          "type": "string",
          "description": "A notable quote from the scene."
        },
        "note": {
          "type": "string",
          "description": "Personal note about why this scene is memorable."
        },
        "addedDate": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "userId",
        "movieId",
        "movieTitle",
        "timestamp",
        "addedDate"
      ]
    },
    "WatchParty": {
      "title": "WatchParty",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "hostId": { "type": "string" },
        "hostName": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "scheduledAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["draft", "voting", "ready", "finished"] },
        "selectedMovieId": { "type": "string" },
        "selectedMovieTitle": { "type": "string" },
        "selectedMoviePoster": { "type": "string" }
      }
    },
    "WatchPartyNomination": {
      "title": "WatchPartyNomination",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "movieId": { "type": "string" },
        "movieTitle": { "type": "string" },
        "posterUrl": { "type": "string" },
        "nominatorId": { "type": "string" },
        "nominatorName": { "type": "string" },
        "votes": { "type": "object", "description": "Map of userId to boolean for voting" }
      }
    },
    "WatchPartyMember": {
      "title": "WatchPartyMember",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "UserId as DocId" },
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "joinedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "Stores user profile information."
        }
      },
      {
        "path": "/users/{userId}/watchlist/{watchlistEntryId}",
        "definition": {
          "entityName": "WatchlistEntry",
          "schema": {
            "$ref": "#/backend/entities/WatchlistEntry"
          },
          "description": "Contains user watchlist entries."
        }
      },
      {
        "path": "/users/{userId}/sceneMemories/{memoryId}",
        "definition": {
          "entityName": "SceneMemory",
          "schema": {
            "$ref": "#/backend/entities/SceneMemory"
          },
          "description": "Stores a user's specific scene memories for various movies."
        }
      },
      {
        "path": "/watchParties/{partyId}",
        "definition": {
          "entityName": "WatchParty",
          "schema": {
            "$ref": "#/backend/entities/WatchParty"
          },
          "description": "Root watch party details"
        }
      },
      {
        "path": "/watchParties/{partyId}/nominations/{nominationId}",
        "definition": {
          "entityName": "WatchPartyNomination",
          "schema": {
            "$ref": "#/backend/entities/WatchPartyNomination"
          },
          "description": "Movies nominated for a watch party"
        }
      },
      {
        "path": "/watchParties/{partyId}/members/{memberId}",
        "definition": {
          "entityName": "WatchPartyMember",
          "schema": {
            "$ref": "#/backend/entities/WatchPartyMember"
          },
          "description": "Members of a watch party"
        }
      }
    ]
  }
}
