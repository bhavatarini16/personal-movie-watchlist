{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile in the CineTrack application.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "username": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "dateJoined": { "type": "string", "format": "date-time" },
        "personality": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "description": { "type": "string" }
          }
        },
        "friends": {
          "type": "object",
          "description": "A map of userId to boolean for fast access control checks."
        }
      },
      "required": ["id", "email", "username"]
    },
    "WatchlistEntry": {
      "title": "WatchlistEntry",
      "type": "object",
      "description": "A movie entry in a user's watchlist.",
      "properties": {
        "userId": { "type": "string" },
        "movieId": { "type": "string" },
        "movieData": { "type": "object" },
        "addedDate": { "type": "string", "format": "date-time" },
        "isWatched": { "type": "boolean" },
        "watchDate": { "type": "string", "format": "date-time" },
        "personalRating": { "type": "number" },
        "notes": { "type": "string" },
        "rewatchCount": { "type": "number" },
        "isFavorite": { "type": "boolean" },
        "remindMe": { "type": "boolean" }
      },
      "required": ["userId", "movieId", "isWatched"]
    },
    "SceneMemory": {
      "title": "SceneMemory",
      "type": "object",
      "description": "A specific cinematic moment captured by a user.",
      "properties": {
        "userId": { "type": "string" },
        "movieId": { "type": "string" },
        "movieTitle": { "type": "string" },
        "posterUrl": { "type": "string" },
        "timestamp": { "type": "string" },
        "quote": { "type": "string" },
        "note": { "type": "string" },
        "addedDate": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "movieId", "timestamp"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Core user profiles."
    },
    "/users/{userId}/watchlist/{itemId}": {
      "schema": { "$ref": "#/backend/entities/WatchlistEntry" },
      "description": "User's personal movie tracking queue."
    },
    "/users/{userId}/sceneMemories/{memoryId}": {
      "schema": { "$ref": "#/backend/entities/SceneMemory" },
      "description": "User's personal cinematic notes and highlights."
    },
    "/users/{userId}/notifications/{notifId}": {
      "schema": "object",
      "description": "User's activity alerts and invitations."
    },
    "/watchParties/{partyId}": {
      "schema": "object",
      "description": "Collaborative watch party rooms."
    },
    "/comments/{commentId}": {
      "schema": "object",
      "description": "Global movie discussion comments."
    }
  }
}