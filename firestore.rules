
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isFriendOf(targetUserId) {
      let userPath = /databases/$(database)/documents/users/$(targetUserId);
      return isSignedIn() && 
             exists(userPath) &&
             request.auth.uid in get(userPath).data.get('friends', {});
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get, list: if isOwner(userId) || isFriendOf(userId);
      allow create: if isOwner(userId); 
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);

      match /watchlist/{watchlistEntryId} {
        allow read: if isOwner(userId) || isFriendOf(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == userId;
        allow delete: if isExistingOwner(userId);
      }

      match /sceneMemories/{memoryId} {
        allow read: if isOwner(userId) || isFriendOf(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == userId;
        allow delete: if isExistingOwner(userId);
      }
    }

    match /watchParties/{partyId} {
      // Helper for party members
      function isPartyMember() {
        return exists(/databases/$(database)/documents/watchParties/$(partyId)/members/$(request.auth.uid));
      }
      
      function isHost() {
        return resource != null && resource.data.hostId == request.auth.uid;
      }

      allow list, get: if isSignedIn(); // Allow discovery for joining
      allow create: if isSignedIn() && request.resource.data.hostId == request.auth.uid;
      allow update: if isHost() || (isPartyMember() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'selectedMovieId', 'selectedMovieTitle', 'selectedMoviePoster']));
      allow delete: if isHost();

      match /members/{memberId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && memberId == request.auth.uid;
        allow delete: if isSignedIn() && (memberId == request.auth.uid || isHost());
      }

      match /nominations/{nominationId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isPartyMember();
      }
    }

    match /movies/{movieId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /comments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /genres/{genreId} {
      allow read: if isSignedIn();
    }
  }
}
