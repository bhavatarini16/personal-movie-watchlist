
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MOVIE WATCHLIST APP SECURITY RULES
     * 
     * Core Philosophy:
     * This ruleset enforces a strict user-ownership model for personal data (profiles, watchlists) 
     * while enabling social features through a "Friends" access model. Public movie data is 
     * globally readable by authenticated users but strictly read-only from the client.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isFriendOf(targetUserId) {
      return isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/users/$(targetUserId)).data.friends;
    }

    function isDataOwner(fieldName) {
      return isSignedIn() && request.resource.data[fieldName] == request.auth.uid;
    }

    function isExistingDataOwner(fieldName) {
      return resource != null && isSignedIn() && resource.data[fieldName] == request.auth.uid;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get, list: if isOwner(userId) || isFriendOf(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == userId;
      allow delete: if isExistingOwner(userId);

      match /watchlist/{watchlistEntryId} {
        allow get, list: if isOwner(userId) || isFriendOf(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == userId;
        allow delete: if isExistingOwner(userId);
      }
    }

    match /movies/{movieId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /genres/{genreId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /persons/{personId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /moviePersonalityTypes/{typeId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /friendships/{friendshipId} {
      allow get, list: if isSignedIn() && (resource.data.requesterId == request.auth.uid || resource.data.addresseeId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.requesterId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.requesterId == request.auth.uid || resource.data.addresseeId == request.auth.uid);
      allow delete: if isSignedIn() && (resource.data.requesterId == request.auth.uid || resource.data.addresseeId == request.auth.uid);
    }

    match /comments/{commentId} {
      // Simplified read rules to allow all signed-in users to see movie discussions
      allow get, list: if isSignedIn();
      allow create: if isDataOwner('userId');
      allow update: if isExistingDataOwner('userId') && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingDataOwner('userId');
    }

    match /reactions/{reactionId} {
      allow get, list: if isSignedIn();
      allow create: if isDataOwner('userId');
      allow update: if isExistingDataOwner('userId') && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingDataOwner('userId');
    }
  }
}
