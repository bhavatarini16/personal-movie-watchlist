rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CineTrack Security Rules
     * 
     * Core Philosophy:
     * - Users have full recursive access to their own profile and all subcollections.
     * - Watch Parties are readable by any signed-in user.
     * - Comments are public for reading, restricted for creation/editing.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    /**
     * @description User Profiles and all nested private data.
     * Recursively allows the owner to read and write any document in their tree.
     */
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    /**
     * @description Watch Parties - Collaborative movie watching rooms.
     */
    match /watchParties/{partyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      // Allow host/members to update status/metadata/votes
      allow update: if isSignedIn(); 
      allow delete: if isSignedIn() && resource.data.hostId == request.auth.uid;

      // Participants in a specific watch party
      match /members/{memberId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }

      // Movie suggestions and votes
      match /nominations/{nomId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    /**
     * @description Public movie discussion comments.
     */
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}