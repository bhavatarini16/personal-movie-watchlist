
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Rules ---

    // Users have absolute authority over their own profile and all nested sub-data
    // Using a recursive wildcard to ensure all subcollections are explicitly covered
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // Comments are public to read, restricted to signed-in authors for writing
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Watch Parties are collaborative spaces for signed-in users
    match /watchParties/{partyId} {
      allow read, create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource == null || resource.data.hostId == request.auth.uid);

      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }
  }
}
