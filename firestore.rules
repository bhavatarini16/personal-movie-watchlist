rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CineTrack Security Rules
     * 
     * Core Philosophy:
     * Implements a robust security model prioritizing user privacy via path-based ownership.
     * Public catalog data is readable by all, while personal data (watchlist, memories) 
     * is strictly restricted to the owner.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description User Profiles and their private subcollections.
     */
    match /users/{userId} {
      // Allow the owner to read and write their own profile
      allow get, create, update: if isOwner(userId);
      // Admin override
      allow get: if isAdmin();
      allow list: if isAdmin();

      // User's private watchlist
      match /watchlist/{itemId} {
        allow read, write: if isOwner(userId);
      }

      // User's private cinematic memories
      match /sceneMemories/{memoryId} {
        allow read, write: if isOwner(userId);
      }

      // User's private notifications
      match /notifications/{notifId} {
        allow read, write: if isOwner(userId);
      }
    }

    /**
     * @description Movie Catalog (Public Read, Admin Write).
     * These paths match the mock service and potential future additions.
     */
    match /movies/{movieId} { allow read: if true; allow write: if isAdmin(); }
    match /genres/{genreId} { allow read: if true; allow write: if isAdmin(); }
    match /actors/{actorId} { allow read: if true; allow write: if isAdmin(); }

    /**
     * @description Public comments on movies.
     */
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    /**
     * @description Watch Parties - Collaborative movie watching rooms.
     */
    match /watchParties/{partyId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn(); // Basic update for members
      allow delete: if isSignedIn() && request.auth.uid == resource.data.hostId;

      match /members/{memberId} {
        allow read: if isSignedIn();
        // User joining themselves or Host adding a member
        allow create, update, delete: if isSignedIn() && (request.auth.uid == memberId || request.auth.uid == get(/databases/$(database)/documents/watchParties/$(partyId)).data.hostId);
      }

      match /nominations/{nomId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn(); // Allow voting and nominating
        allow delete: if isSignedIn() && (request.auth.uid == resource.data.nominatorId || request.auth.uid == get(/databases/$(database)/documents/watchParties/$(partyId)).data.hostId);
      }
    }

    /**
     * @description friendship requests and connections.
     */
    match /friendships/{friendshipId} {
      allow read, write: if isSignedIn() && (request.auth.uid == resource.data.user1Id || request.auth.uid == resource.data.user2Id);
    }

    /**
     * @description Administrative Roles.
     */
    match /roles_admin/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
  }
}